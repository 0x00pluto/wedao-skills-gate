# 首页「一键安装」展示的站点根地址（无末尾斜杠）。不填时由浏览器当前访问 origin 作为展示用 URL。
# 生产环境建议设为对外 HTTPS 根地址，例如 https://skills.example.com
NEXT_PUBLIC_SKILLS_GATE_ORIGIN=

# GitHub App：复制为 .env.local 后填入真实值（勿将密钥提交到 Git）
# Token API：GET /api/token 的 query 参数 key 须与 Supabase public.companies.enterprise_key 一致，并配合 skillId 与 company_skills 授权（生产环境务必使用 HTTPS）

# App 设置页可查看
GITHUB_APP_ID=你的AppID

# 安装到组织/仓库后的 Installation ID
GITHUB_INSTALLATION_ID=你的安装ID

# 私钥建议转成 Base64 或直接粘贴 PEM；Vercel 后台支持多行
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Supabase（与 Dashboard「Project Settings → API」一致；勿提交含真实密钥的 .env.local）
# 浏览器可访问的客户端：URL + anon（公开，受 RLS 约束）
NEXT_PUBLIC_SUPABASE_URL=https://你的项目ref.supabase.co
SUPABASE_ANON_KEY=你的anon公钥
# 仅服务端使用（Route Handler / Server Actions 等），切勿使用 NEXT_PUBLIC_；可绕过 RLS，勿泄露
SUPABASE_SERVICE_ROLE_KEY=你的service_role密钥
# 可选：自行校验 JWT、或工具链明确要求时再填；多数仅用 Supabase 客户端时可不配置
# SUPABASE_JWT_SECRET=

# 管理员同步：POST /api/admin/sync 请求头 x-api-key 须与此一致（勿泄露）
ADMIN_SYNC_API_KEY=你的同步接口密钥

# 管理后台登录会话签名密钥（至少 32 位随机字符串；仅服务端使用）
# 可用命令生成示例：openssl rand -base64 32
ADMIN_SESSION_SECRET=请替换成随机长字符串

# 技能索引 YAML 所在仓库与路径（默认与 WeDAOLabs/skills-hub 的 skills.index.yaml 一致）
# SKILLS_HUB_OWNER=WeDAOLabs
# SKILLS_HUB_REPO=skills-hub
# SKILLS_HUB_INDEX_PATH=skills.index.yaml

# 说明：Vercel 关联 Supabase 可能同步 POSTGRES_*、SUPABASE_URL 等与直连库/平台相关的变量；
# 若代码未使用 Prisma 等直连 Postgres，通常只需上面三项即可。
