# 首页「一键安装」展示的站点根地址（无末尾斜杠）。不填时由浏览器当前访问 origin 作为展示用 URL。
# 生产环境建议设为对外 HTTPS 根地址，例如 https://skills.example.com
NEXT_PUBLIC_SKILLS_GATE_ORIGIN=

# GitHub App：复制为 .env.local 后填入真实值（勿将密钥提交到 Git）
# 调用安装令牌 API 时传入的 query key，须与请求参数 ?key= 一致（生产环境务必使用 HTTPS）
VALID_COMPANY_KEY=你的企业Key

# App 设置页可查看
GITHUB_APP_ID=你的AppID

# 安装到组织/仓库后的 Installation ID
GITHUB_INSTALLATION_ID=你的安装ID

# 私钥建议转成 Base64 或直接粘贴 PEM；Vercel 后台支持多行
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
